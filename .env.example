# Resend API key for contact form emails
RESEND_API_KEY=

# Email address that receives contact form submissions (optional)
CONTACT_TO_EMAIL=

# Verified sender in Resend (optional, defaults to "Acme <onboarding@resend.dev>")
# Format: "Name <email@domain.com>"
CONTACT_FROM=

# Production URL (optional, used for sitemap/robots)
SITE_URL=

# Upstash Redis for persistent rate limiting (optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
